{
  "name": "ipmsg-torrent",
  "version": "1.0.0",
  "description": "Decentralized P2P chat application with multi-platform support",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:web": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder --win --linux",
    "android:init": "npx cap init IPMsgTorrent com.ipmsg.torrent android && npx cap add android",
    "android:build": "npm run build && npx cap copy android && npx cap sync android",
    "android:apk": "npm run android:build && cd android && ./gradlew assembleRelease",
    "android:debug": "npm run android:build && cd android && ./gradlew assembleDebug",
    "capacitor:copy": "npx cap copy",
    "capacitor:sync": "npx cap sync",
    "capacitor:open": "npx cap open android",
    "build:win": "vite build && electron-builder --win",
    "build:linux": "vite build && electron-builder --linux",
    "build:mac": "vite build && electron-builder --mac",
    "build:all": "vite build && electron-builder --win --linux --mac"
  },
  "keywords": [
    "ipmsg",
    "p2p",
    "chat",
    "decentralized",
    "webrtc",
    "electron",
    "capacitor",
    "android",
    "harmonyos"
  ],
  "author": "IPMsg Torrent Team <ipmsg@example.com>",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "astral-regex": "^2.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.ipmsg.torrent",
    "productName": "IPMsg Torrent",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-${arch}-win.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "IPMsg Torrent"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons",
      "category": "Network",
      "artifactName": "${productName}-${version}-${arch}-linux.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.social-networking"
    }
  }
}
