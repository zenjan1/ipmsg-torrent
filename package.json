{
  "name": "ppx-chat",
  "version": "1.0.0",
  "description": "PPX - 去中心化P2P聊天应用，集成文件传输、下载管理、媒体播放功能",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:web": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder --win --linux",
    "android:init": "npx cap init PPX com.ppx.chat android && npx cap add android",
    "android:build": "npm run build && npx cap copy android && npx cap sync android",
    "android:apk": "npm run android:build && cd android && ./gradlew assembleRelease",
    "android:debug": "npm run android:build && cd android && ./gradlew assembleDebug",
    "build:win": "vite build && electron-builder --win portable",
    "build:linux": "vite build && electron-builder --linux tar.gz",
    "build:all": "vite build && electron-builder --win portable --linux tar.gz"
  },
  "keywords": [
    "p2p",
    "chat",
    "decentralized",
    "webrtc",
    "electron",
    "capacitor",
    "file-transfer",
    "去中心化",
    "聊天"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.4.21",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.ppx.chat",
    "productName": "PPX",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-win-portable.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "tar.gz",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-linux-x64.${ext}"
    },
    "asar": true,
    "compression": "maximum"
  }
}
