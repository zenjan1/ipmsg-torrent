{
  "appId": "com.ppx.chat",
  "appName": "PPX",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#F5F5F5",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#07C160"
    }
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#F5F5F5"
  }
}
